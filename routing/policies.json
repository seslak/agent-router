    "large": {"inputTokens": 120000, "cachedInputTokens": 40000, "outputTokens": 10000}
  },
  "tierBands": {"cheapMaxCredits": 5, "balancedMaxCredits": 25},
  "taskPolicies": {
    "small_code_edit": {"maxCredits": 5, "costProfile": "small", "preferredSpecialist": "code-editor", "maxTier": "cheap"},
    "documentation_update": {"maxCredits": 5, "costProfile": "small", "preferredSpecialist": "doc-writer", "maxTier": "cheap"},
    "test_failure_simple": {"maxCredits": 15, "costProfile": "medium", "preferredSpecialist": "test-fixer", "maxTier": "balanced"},
    "test_failure_repeated": {"maxCredits": 25, "costProfile": "medium", "preferredSpecialist": "test-fixer", "maxTier": "balanced", "minTier": "balanced"},
    "cross_package_design": {"maxCredits": 25, "costProfile": "medium", "preferredSpecialist": "architect", "maxTier": "balanced"},
    "major_agentic_architecture": {"maxCredits": 100, "costProfile": "large", "preferredSpecialist": "deep-architect", "maxTier": "expensive"},
    "memory_feedback": {"maxCredits": 5, "costProfile": "small", "preferredSpecialist": "memory-feedback-writer", "maxTier": "cheap"},
    "document_ingestion": {"maxCredits": 5, "costProfile": "small", "preferredSpecialist": "doc-writer", "maxTier": "cheap"},
    "unknown": {"maxCredits": 15, "costProfile": "medium", "preferredSpecialist": "architect", "maxTier": "balanced"},
    "context_inspection": {"maxCredits": 5, "costProfile": "small", "preferredSpecialist": "tooling-integrator", "maxTier": "cheap"},
    "alias_curation": {"maxCredits": 5, "costProfile": "small", "preferredSpecialist": "memory-feedback-writer", "maxTier": "cheap"}
  },
  "approvalRules": [
    {"condition": "tier_expensive", "reason": "Expensive model tier requires approval before use."},
    {"condition": "model_requires_approval", "reason": "Selected model requires explicit approval."},
    {"condition": "specialist_approval_always", "reason": "Specialist policy requires approval for all routes."},
    {"condition": "long_context_pricing", "reason": "Estimated input exceeds the model's long-context threshold; higher pricing applies."}
