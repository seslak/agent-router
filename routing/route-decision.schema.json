{
  "type": "object",
  "required": ["decisionId", "createdAt", "task", "taskClass", "routeType", "modelTier", "approvalRequired", "reason", "matchedSignals", "rankedModels"],
  "properties": {
    "decisionId": {"type": "string", "description": "Unique decision identifier with rd_ prefix."},
    "createdAt": {"type": "string", "description": "ISO 8601 timestamp."},
    "sessionId": {"type": "string", "description": "Suite session id when AGENT_SUITE_SESSION_ID is set."},
    "task": {"type": "string", "description": "Original task text."},
    "taskClass": {"type": "string", "description": "Classified task class id."},
    "routeType": {"type": "string", "enum": ["WORKFLOW", "SPECIALIST_AGENT", "MANUAL_PLAN_FIRST"]},
    "workflowId": {"type": "string", "description": "Workflow id if routeType is WORKFLOW."},
    "specialistId": {"type": "string", "description": "Assigned specialist id."},
    "modelTier": {"type": "string", "enum": ["free", "cheap", "balanced", "expensive", "blocked"]},
    "selectedModelId": {"type": "string", "description": "Selected model id."},
    "modelCategory": {"type": "string", "description": "Selected model category."},
    "maxAllowedCredits": {"type": "number", "description": "Max credits allowed for this route."},
    "maxAllowedMultiplier": {"type": "string", "description": "Deprecated compatibility field; null in v0.3.0+."},
    "estimatedCredits": {"type": "number", "description": "Estimated AI credits for the selected model."},
    "costProfile": {"type": "string", "description": "Named cost profile used for estimation."},
    "pricingApplied": {"type": "string", "enum": ["default", "long_context", "blocked"]},
    "estimatedInputTokens": {"type": "number", "description": "Optional caller-supplied input token estimate."},
    "registryAsOf": {"type": "string", "description": "Model registry asOf date."},
    "approvalRequired": {"type": "boolean", "description": "Whether approval is required before proceeding."},
    "approvalReason": {"type": "string", "description": "Why approval is required, if applicable."},
    "approvalConditions": {"type": "array", "items": {"type": "string"}},
    "riskLevel": {"type": "string", "enum": ["low", "medium", "high"]},
    "complexity": {"type": "string", "enum": ["low", "medium", "high"]},
    "blastRadius": {"type": "string", "enum": ["low", "medium", "high"]},
    "allowedTools": {"type": "array", "items": {"type": "string"}},
    "requiredMemory": {"type": "array", "items": {"type": "string"}},
    "requiredChecks": {"type": "array", "items": {"type": "string"}},
    "reason": {"type": "string", "description": "Human-readable routing rationale."},
    "matchedSignals": {"type": "array", "items": {"type": "string"}},
    "fallbackUsed": {"type": "boolean"},
    "blocked": {"type": "boolean"},
    "blockReason": {"type": "string"},
    "nextStep": {"type": "string"},
    "rankedModels": {"type": "array", "items": {"type": "object"}},
    "skipped": {"type": "object", "description": "Diagnostics for filtered candidate models."},
    "warnings": {"type": "array", "items": {"type": "string"}},
    "unknownCandidateModels": {"type": "array", "items": {"type": "string"}},
    "candidateConstraint": {"type": "object", "description": "Constraint details when candidate_models is supplied."},
    "governorStartHint": {"type": "object", "description": "Convenience next governor call when a workflow profile exists."},
    "idealModelId": {"type": "string", "description": "Best unconstrained model id when candidate filtering blocked the route."}
  }
}
